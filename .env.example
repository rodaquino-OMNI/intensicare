# =============================================================================
# Intensicare — Variáveis de Ambiente (Desenvolvimento Local)
# Copie este arquivo para .env e ajuste conforme necessário.
# =============================================================================

# ---------------------------------------------------------------------------
# Ambiente
# ---------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=DEBUG
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# ---------------------------------------------------------------------------
# PostgreSQL + TimescaleDB
# ---------------------------------------------------------------------------
POSTGRES_USER=intensicare
POSTGRES_PASSWORD=intensicare_dev
POSTGRES_DB=intensicare
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_MIN_CONNECTIONS=2
POSTGRES_MAX_CONNECTIONS=10

# Connection string async
DATABASE_URL=postgresql+asyncpg://intensicare:intensicare_dev@localhost:5432/intensicare

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# TimescaleDB (extensões)
# ---------------------------------------------------------------------------
TIMESCALEDB_TELEMETRY=off

# ---------------------------------------------------------------------------
# Observabilidade (opcional em dev)
# ---------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=intensicare-api
